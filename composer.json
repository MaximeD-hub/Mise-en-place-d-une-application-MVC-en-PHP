{
    "name": "maxime-dubois/touche-pas-au-klaxon",
    "description": "Application de covoiturage inter-sites",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "izniburak/router": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse app --level=5"
    }
}
